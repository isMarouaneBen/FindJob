# ============================================================================
#  FindJob — environment template
#  Copy this file to `.env` and fill in the values for your environment.
#  The real `.env` is git-ignored.
# ============================================================================

# ---- Third-party APIs --------------------------------------------------------
# Adzuna (https://developer.adzuna.com/)
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# ---- Google OAuth -----------------------------------------------------------
# The same client ID is used by the frontend (VITE_GOOGLE_CLIENT_ID) and the
# backend (audience verification of the ID token).
# Create one at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ---- Auth secrets -----------------------------------------------------------
# Long random string (>=32 chars). Generate with:  openssl rand -hex 48
JWT_SECRET=change-me-in-production-please-make-this-long-and-random

# Shared secret between Airflow and the FastAPI admin endpoints
# (POST /api/v1/admin/embed-offers).
ADMIN_TOKEN=change-me-shared-with-airflow

# ---- Postgres ---------------------------------------------------------------
POSTGRES_USER=datauser
POSTGRES_PASSWORD=datapass
POSTGRES_DB=job_db

# ---- MongoDB ---------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123

# ---- MinIO (S3 for CV uploads) ---------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---- Airflow ----------------------------------------------------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin123
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=change-me

# ---- pgAdmin / Mongo-Express UI ---------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@jobintelligent.ma
PGADMIN_DEFAULT_PASSWORD=admin123
ME_BASICAUTH_USER=admin
ME_BASICAUTH_PASSWORD=admin123
